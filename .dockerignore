# Dependencies (reinstalled inside Docker)
node_modules
**/node_modules

# Git history
.git
.gitignore

# Replit-specific
.local
.replit
replit.nix
attached_assets

# The api-server is now bundled into the combined Dockerfile.
# artifacts/api-server is required.
artifacts/mockup-sandbox

# Don't ship api-server's pre-built dist into the build context — it
# gets rebuilt inside the image, and including the local dist could
# pollute the context with stale builds.
artifacts/api-server/dist

# Build artefacts that will be regenerated
artifacts/eds-site/dist

# Env files
.env
.env.*
*.local

# Logs
*.log
npm-debug.log*
